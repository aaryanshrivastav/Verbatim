# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/microservices_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Inter-service URLs
AUTH_SERVICE_URL=http://localhost:8001
CATALOG_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8004

# Retry settings (for order service payment calls)
ENABLE_RETRY_STORM=true
MAX_RETRIES=3
INITIAL_BACKOFF_SECONDS=1
MAX_BACKOFF_SECONDS=32

# HTTP timeouts
HTTP_TIMEOUT_SECONDS=10
DB_POOL_SIZE=10

# Payment simulation rates (payment service)
PAYMENT_SUCCESS_RATE=0.8
PAYMENT_TIMEOUT_RATE=0.1
